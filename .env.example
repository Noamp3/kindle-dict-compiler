# ==============================================================================
# Environment Configuration Template for Dictionary Translation
# Copy this file to `.env` and fill in your actual credentials.
# Do NOT commit the `.env` file to version control.
# ==============================================================================

# 1. Google Gemini API Keys (Required for translation via translate_batches.py)
# You can obtain an API key from Google AI Studio.
GEMINI_API_KEY=your_gemini_api_key_here

# 2. Secondary Gemini API Key (Optional)
# Used to bypass rate limits when running multiple parallel translation runners.
GEMINI_API_KEY2=your_secondary_gemini_api_key_here

# 3. Optional: Groq API Key (If using any alternative models/endpoints in scratch scripts)
groq_key=your_groq_api_key_here
